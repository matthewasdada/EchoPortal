body {
    font-family: Arial;
    text-align: center;
    background-color: #595858; /* grey colour */

}

form {
    background: grey;
    padding: 20px;
    margin: 50px auto;
    width: 300px;
    border-radius: 10px;
}

button {
    padding: 10px;
    background-color: #dfe82e; /* yellow colour */
    color: black;
    border: none;
    border-radius: 5px;
    width: 100%;
}

img {
    margin: 10px;
    border-radius: 10px;
}